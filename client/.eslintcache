oal\\GoalLT.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\components\\goal\\GoalMT.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\components\\goal\\GoalST.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\reducers\\actionReducer.js",[],"D:\\Make-it-happen\\development\\client\\src\\components\\action\\ModalAddAction.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\actions\\action_actions.js",[],"D:\\Make-it-happen\\development\\client\\src\\components\\action\\Action.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\components\\action\\ModalDeleteAction.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\components\\action\\ModalEditAction.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\components\\tools\\Promodoro.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\reducers\\promodoroReducer.js",[],"D:\\Make-it-happen\\development\\client\\src\\actions\\promodoro_actions.js",[],"D:\\Make-it-happen\\development\\client\\src\\components\\nav\\auth\\ImageUpload.js",[],"D:\\Make-it-happen\\development\\client\\src\\components\\goal\\Partners.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\chat\\Chat.jsx",["219","220"],"import React, { useEffect } from \"react\";\r\nimport { useDispatch, useSelector } from \"react-redux\";\r\nimport { useParams } from \"react-router\";\r\nimport { loadChats } from \"../actions/chat_actions\";\r\nimport \"./Chat.css\";\r\nimport Discussion from \"./Discussion\";\r\nimport Sidebar from \"./Sidebar\";\r\nimport Pusher from \"pusher-js\";\r\nimport { CHAT_ADD_SUCCESS } from \"../actions/actionsTypes\";\r\n\r\nexport default function Chat() {\r\n  const { partners } = useSelector((state) => state.goal);\r\n  const partnerId = useParams().partnerId;\r\n  const dispatch = useDispatch();\r\n  useEffect(() => {\r\n    dispatch(loadChats());\r\n\r\n    // const pusher = new Pusher(\"22769e8d448bb4cddf2c\", {\r\n    //   cluster: \"eu\",\r\n    // });\r\n    // const channel = pusher.subscribe(\"chats\");\r\n    // var newMsg = null;\r\n    // channel.bind(\"updated\", function (data) {\r\n    //   newMsg = data;\r\n    //   if (newMsg) {\r\n    //     dispatch({ type: CHAT_ADD_SUCCESS, payload: newMsg });\r\n    //     newMsg = null;\r\n    //   }\r\n    // });\r\n  }, [dispatch]);\r\n\r\n  return (\r\n    <div className=\"chat\">\r\n      <Sidebar />\r\n      <Discussion\r\n        partner={partners?.filter((partner) => partner._id === partnerId)[0]}\r\n      />\r\n    </div>\r\n  );\r\n}\r\n","D:\\Make-it-happen\\development\\client\\src\\chat\\Discussion.jsx",["221","222"],"import React, { useEffect, useRef, useState } from \"react\";\r\nimport { Button, Icon } from \"semantic-ui-react\";\r\nimport \"./Discussion.css\";\r\nimport InputEmoji from \"react-input-emoji\";\r\nimport { addMsg } from \"../actions/chat_actions\";\r\nimport { useDispatch, useSelector } from \"react-redux\";\r\nimport { CHAT_RESET_NOTIF } from \"../actions/actionsTypes\";\r\nimport { useParams } from \"react-router\";\r\n\r\nexport default function Discussion({ partner }) {\r\n  const [text, setText] = useState(\"\");\r\n  const [messages, setMessages] = useState([]);\r\n  const { chats } = useSelector((state) => state.chats);\r\n  const { partners } = useSelector((state) => state.goal);\r\n  const textinput = useRef();\r\n  const lastMsg = useRef();\r\n  const dispatch = useDispatch();\r\n  const partnerId = useParams().partnerId;\r\n\r\n  useEffect(() => {\r\n    lastMsg.current.scrollIntoView({ behavior: \"smooth\" });\r\n  }, []);\r\n  useEffect(() => {\r\n    dispatch({ type: CHAT_RESET_NOTIF });\r\n    setMessages(\r\n      chats?.filter(\r\n        (chat) =>\r\n          chat.chatUsers[0]?._id === partnerId ||\r\n          chat.chatUsers[1]?._id === partnerId\r\n      )[0]?.messages\r\n    );\r\n  }, [chats, partner?._id, dispatch]);\r\n\r\n  useEffect(() => {\r\n    lastMsg.current.scrollIntoView({ behavior: \"smooth\" });\r\n  }, [messages]);\r\n\r\n  const sendMsg = () => {\r\n    let data = { text, partnerId: partner._id, timestamp: Date.now() };\r\n    dispatch(addMsg(data));\r\n    textinput.current.value = \"\";\r\n    textinput.current.focus();\r\n  };\r\n\r\n  return (\r\n    <div className=\"discussion\">\r\n      <div className=\"discussion__header\">\r\n        <img src={`/${partner?.image}`} alt=\"\" className=\"discussion__img\" />\r\n        <div className=\"discussion__header-info\">\r\n          <p className=\"discussion__header-user\">\r\n            {partner?.firstName + \" \" + partner?.lastName}\r\n          </p>\r\n          {/* <p className=\"discussion__header-msg\">last seen at</p> */}\r\n        </div>\r\n      </div>\r\n      <div className=\"discussion__body\">\r\n        {messages?.map((msg) => (\r\n          <div\r\n            key={msg._id}\r\n            className={\r\n              \"discussion__msg \" + (msg.userId !== partner._id ? \"sent\" : \" \")\r\n            }\r\n          >\r\n            <p className=\"discussion__msg-text\">{msg.text}</p>\r\n            <p className=\"discussion__msg-time\">\r\n              {new Date(msg.timeStamp).toLocaleTimeString().slice(0, 5)}\r\n            </p>\r\n          </div>\r\n        ))}\r\n        <div ref={lastMsg}></div>\r\n      </div>\r\n      <div className=\"discussion__footer\">\r\n        <InputEmoji\r\n          value={text}\r\n          onChange={setText}\r\n          cleanOnEnter={false}\r\n          placeholder=\"Type a message\"\r\n          className=\"discussion__input\"\r\n          ref={textinput}\r\n        />\r\n        <Button onClick={sendMsg}>\r\n          <Icon name=\"send\" />\r\n          Send\r\n        </Button>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n","D:\\Make-it-happen\\development\\client\\src\\chat\\Sidebar.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\reducers\\chatReducer.js",[],"D:\\Make-it-happen\\development\\client\\src\\actions\\chat_actions.js",[],"D:\\Make-it-happen\\development\\client\\src\\compone