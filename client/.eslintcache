Path":"269","messages":"270","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"140"},{"filePath":"271","messages":"272","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"140"},{"filePath":"273","messages":"274","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"140"},{"filePath":"275","messages":"276","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"140"},"/home/nabil/Make-it-happen/client/src/index.js",[],["277","278"],"/home/nabil/Make-it-happen/client/src/App.js",[],"/home/nabil/Make-it-happen/client/src/reportWebVitals.js",[],"/home/nabil/Make-it-happen/client/src/serviceWorkerRegistration.js",[],"/home/nabil/Make-it-happen/client/src/store/configureStore.js",[],"/home/nabil/Make-it-happen/client/src/reducers/rootReducer.js",[],"/home/nabil/Make-it-happen/client/src/pages/Home.jsx",[],"/home/nabil/Make-it-happen/client/src/pages/CheckoutSuccess.jsx",[],"/home/nabil/Make-it-happen/client/src/pages/FieldPage.jsx",["279","280"],"import React, { useEffect, useState } from \"react\";\nimport { useDispatch, useSelector } from \"react-redux\";\nimport { Icon, Loader } from \"semantic-ui-react\";\nimport { loadFields } from \"../actions/field_actions\";\nimport { loadQuote } from \"../actions/loadQuote\";\nimport Field from \"../components/field/Field\";\nimport ModalAddField from \"../components/field/ModalAddField\";\nimport { format } from \"date-fns\";\n\nimport \"./FieldPage.css\";\nimport { loadTodayActions } from \"../actions/action_actions\";\nimport Action from \"../components/action/Action\";\nimport CareerIcon from \"../icons/CareerIcon\";\nimport FinanceIcon from \"../icons/FinanceIcon\";\nimport HealthIcon from \"../icons/HealthIcon\";\nimport FunIcon from \"../icons/FunIcon\";\nimport GrowthIcon from \"../icons/GrowthIcon\";\nimport RelationsIcon from \"../icons/RelationsIcon\";\n\nexport default function FieldPage() {\n  const dispatch = useDispatch();\n  const { quote, author, loadingQuote } = useSelector((state) => state.quote);\n  const { loadingField, name } = useSelector((state) => state.field);\n  const { loadingAction, todayActions, completedActionsOfToday } = useSelector(\n    (state) => state.action\n  );\n  const [openModalAdd, setOpenModalAdd] = useState(false);\n\n  useEffect(() => {\n    dispatch(loadQuote());\n    dispatch(loadFields());\n    dispatch(loadTodayActions());\n  }, [dispatch]);\n\n  const handleAddField = () => {\n    setOpenModalAdd(!openModalAdd);\n  };\n  const fieldsIcons = [\n    CareerIcon,\n    FinanceIcon,\n    HealthIcon,\n    GrowthIcon,\n    FunIcon,\n    RelationsIcon,\n  ];\n\n  return (\n    <div className=\"FieldPage\">\n      <h3> {format(new Date(), \"EEEE dd MMMM\")}</h3>\n      {loadingQuote ? (\n        <Loader active inline=\"centered\" className=\"FieldPage__quote\" />\n      ) : (\n        <div className=\"FieldPage__quote\">\n          <span className=\"FieldPage__quote-content\">\n            {quote.length == 0\n              ? \"You are never too old to set another goal or to dream a new dream.\"\n              : quote}\n          </span>\n          <span className=\"FieldPage__quote-author\">\n            {author.length == 0 ? \"C.S LEWIS\" : author}\n          </span>\n        </div>\n      )}\n\n      <div className=\"FieldPage__content\">\n        <div className=\"FieldPage__sectionFields\">\n          <div className=\"FieldPage__sectionFields-header\">\n            <h2>Life Areas :</h2>\n            <div onClick={handleAddField} className=\"iconAdd\">\n              <Icon name=\"add circle\" />\n            </div>\n            <ModalAddField open={openModalAdd} setOpen={handleAddField} />\n          </div>\n          {loadingField ? (\n            <Loader active className=\"spinner\" />\n          ) : (\n            <div className=\"FielPage__fields\">\n              {name?.map((el, index) => (\n                <Field key={el._id} id={el._id} name={el.name}>\n                  {React.createElement(fieldsIcons[index], {})}\n                </Field>\n              ))}\n            </div>\n          )}\n        </div>\n        <div className=\"FieldPage__actions\">\n          <h2>\n            Today actions done: {completedActionsOfToday} /{\" \"}\n            {todayActions?.length}\n          </h2>\n\n          {loadingAction ? (\n            <Loader active className=\"spinner\" />\n          ) : (\n            <div>\n              {todayActions?.map((action) => (\n                <Action key={action._id} data={action} />\n              ))}\n            </div>\n          )}\n        </div>\n      </div>\n    </div>\n  );\n}\n","/home/nabil/Make-it-happen/client/src/pages/GoalsPage.jsx",[],"/home/nabil/Make-it-happen/client/src/pages/CheckoutFail.jsx",[],"/home/nabil/Make-it-happen/client/src/chat/Chat.jsx",[],"/home/nabil/Make-it-happen/client/src/components/nav/header/Header.jsx",[],"/home/nabil/Make-it-happen/client/src/reducers/authReducer.js",[],"/home/nabil/Make-it-happen/client/src/reducers/fieldReducer.js",[],"/home/nabil/Make-it-happen/client/src/reducers/quoteReducer.js",[],"/home/nabil/Make-it-happen/client/src/reducers/asyncReducer.js",[],"/home/nabil/Make-it-happen/client/src/reducers/chatReducer.js",[],"/home/nabil/Make-it-happen/client/src/reducers/actionReducer.js",[],"/home/nabil/Make-it-happen/client/src/reducers/promodoroReducer.js",[],"/home/nabil/Make-it-happen/client/src/reducers/goalReducer.js",[],"/home/nabil/Make-it-happen/client/src/actions/loadQuote.js",[],"/home/nabil/Make-it-happen/client/src/actions/auth_actions.js",[],"/home/nabil/Make-it-happen/client/src/actions/action_actions.js",[],"/home/nabil/Make-it-happen/client/src/actions/field_actions.js",[],"/home/nabil/Make-it-happen/client/src/actions/goal_actions.js