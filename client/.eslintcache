",[],"D:\\Make-it-happen\\development\\client\\src\\chat\\Discussion.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\chat\\Sidebar.jsx",["205"],"import React from \"react\";\r\nimport { useSelector } from \"react-redux\";\r\nimport { Icon } from \"semantic-ui-react\";\r\nimport \"./Sidebar.css\";\r\n\r\nexport default function Sidebar() {\r\n  const { chats } = useSelector((state) => state.chats);\r\n  const { profile } = useSelector((state) => state.auth);\r\n  return (\r\n    <div className=\"sidebar\">\r\n      <h2>Discussions</h2>\r\n      {chats.map((chat) => (\r\n        <div className=\"sidebar__discussion\" key={chat._id}>\r\n          <img\r\n            src={`/${partner(chat.chatUsers, profile._id)?.image}`}\r\n            alt=\"\"\r\n            className=\"sidebar__discussion-img\"\r\n          />\r\n\r\n          <div>\r\n            <p>\r\n              {partner(chat.chatUsers, profile._id).firstName +\r\n                \"  \" +\r\n                partner(chat.chatUsers, profile.id).lastName}\r\n            </p>\r\n            <p>{chat.messages[chat.messages.length - 1].text}</p>\r\n          </div>\r\n        </div>\r\n      ))}\r\n    </div>\r\n  );\r\n}\r\n\r\nconst partner = (chatUsers, userId) => {\r\n  return chatUsers.filter((user) => user._id !== userId)[0];\r\n};\r\n","D:\\Make-it-happen\\development\\client\\src\\reducers\\chatReducer.js",[],"D:\\Make-it-happen\\development\\client\\src\\actions\\chat_actions.js",[],{"ruleId":"206","replacedBy":"207"},{"ruleId":"208","replacedBy":"209"},{"ruleId":"206","replacedBy":"210"},{"ruleId":"208","replacedBy":"211"},{"ruleId":"212","severity":1,"message":"213","line":3,"column":10,"nodeType":"214","messageId":"215","endLine":3,"endColumn":14},"no-native-reassign",["216"],"no-negated-in-lhs",["217"],["216"],["217"],"no-unused-vars","'Icon' is defined but never used.","Identifier","unusedVar","no-global-assign","no-unsafe-negation"]