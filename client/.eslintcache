ctions.js",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\actions\\goal_actions.js",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\actions\\loadQuote.js",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\actions\\action_actions.js",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\actions\\auth_actions.js",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\actions\\payment_actions.js",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\actions\\chat_actions.js",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\actions\\actionsTypes.js",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\chat\\Discussion.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\chat\\Sidebar.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\icons\\GrowthIcon.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\icons\\FunIcon.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\icons\\RelationsIcon.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\icons\\HealthIcon.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\icons\\CareerIcon.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\icons\\FinanceIcon.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\homePage\\Tool.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\homePage\\Synergy.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\homePage\\Dream.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\homePage\\Plan.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\homePage\\Footer.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\goal\\ModalAddGoal.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\goal\\Partners.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\goal\\GoalLT.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\field\\Field.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\tools\\Promodoro.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\field\\ModalAddField.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\action\\Action.jsx",["279"],"import React, { useState } from \"react\";\r\nimport {\r\n  Checkbox,\r\n  Box,\r\n  Flex,\r\n  Text,\r\n  IconButton,\r\n  HStack,\r\n  Badge,\r\n} from \"@chakra-ui/react\";\r\nimport { EditIcon, DeleteIcon, TimeIcon } from \"@chakra-ui/icons\";\r\nimport \"./Action.css\";\r\nimport ModalDeleteAction from \"./ModalDeleteAction\";\r\nimport ModalEditAction from \"./ModalEditAction\";\r\nimport { format } from \"date-fns\";\r\nimport { editAction } from \"../../actions/action_actions\";\r\nimport { useDispatch } from \"react-redux\";\r\n\r\nexport default function Action({ action }) {\r\n  const { description, startDate, priority, type, completed, _id, fieldId } =\r\n    action;\r\n  const [openModalEdit, setOpenModalEdit] = useState(false);\r\n  const [openModalDelete, setOpenModalDelete] = useState(false);\r\n  const dispatch = useDispatch();\r\n  const isCompletedToday = Boolean(completed?.status);\r\n\r\n  const handleModalDelete = (e) => {\r\n    setOpenModalDelete(!openModalDelete);\r\n  };\r\n\r\n  const handleModalEdit = (e) => {\r\n    setOpenModalEdit(!openModalEdit);\r\n  };\r\n\r\n  const updateCompletedStatus = async (e) => {\r\n    try {\r\n      dispatch(\r\n        editAction({\r\n          ...action,\r\n          completed: {\r\n            status: !isCompletedToday,\r\n            completionDate: action.completed.completionDate,\r\n          },\r\n        }),\r\n      );\r\n    } catch (err) {\r\n      console.error(err);\r\n    }\r\n  };\r\n\r\n  const getThemeColors = () => {\r\n    if (isCompletedToday)\r\n      return {\r\n        border: \"green.400\",\r\n        bg: \"green.50\",\r\n        glow: \"rgba(72, 187, 120, 0.15)\",\r\n      };\r\n    const p = priority?.toLowerCase();\r\n    if (p === \"high\")\r\n      return {\r\n        border: \"red.400\",\r\n        bg: \"red.50\",\r\n        glow: \"rgba(245, 101, 101, 0.15)\",\r\n      };\r\n    if (p === \"medium\")\r\n      return {\r\n        border: \"orange.400\",\r\n        bg: \"orange.50\",\r\n        glow: \"rgba(237, 137, 54, 0.15)\",\r\n      };\r\n    return {\r\n      border: \"gray.300\",\r\n      bg: \"gray.50\",\r\n      glow: \"rgba(160, 174, 192, 0.1)\",\r\n    };\r\n  };\r\n\r\n  const colors = getThemeColors();\r\n\r\n  return (\r\n    <Box\r\n      className=\"action__glass-card\"\r\n      w=\"100%\"\r\n      p={6}\r\n      mb={4}\r\n      bg={isCompletedToday ? colors.bg : \"white\"}\r\n      border=\"1px solid\"\r\n      borderColor={isCompletedToday ? \"green.200\" : \"gray.100\"}\r\n      borderLeft=\"6px solid\"\r\n      borderLeftColor={colors.border}\r\n      borderRadius=\"2xl\"\r\n      boxShadow={`0 10px 25px -5px ${colors.glow}, 0 8px 10px -6px rgba(0,0,0,0.03)`}\r\n      _hover={{\r\n        transform: \"translateY(-4px)\",\r\n        boxShadow: `0 20px 35px -5px ${colors.glow}, 0 12px 16px -8px rgba(0,0,0,0.05)`,\r\n        borderColor: isCompletedToday ? \"green.300\" : \"gray.200\",\r\n      }}\r\n      transition=\"all 0.3s cubic-bezier(0.4, 0, 0.2, 1)\"\r\n    >\r\n      <Flex direction=\"column\" gap={4} w=\"100%\">\r\n        {/* Main Row: Checkbox, Text Description, and Management Controls */}\r\n        <Flex\r\n          width=\"100%\"\r\n          alignItems=\"start\"\r\n          justifyContent=\"space-between\"\r\n          gap={4}\r\n        >\r\n          <HStack spacing={4} alignItems=\"start\" flex=\"1\">\r\n            <Checkbox\r\n              id={`cb-${_id}`}\r\n              isChecked={isCompletedToday}\r\n              onChange={updateCompletedStatus}\r\n              colorScheme=\"green\"\r\n              size=\"lg\"\r\n              mt=\"3px\"\r\n              transform=\"scale(1.2)\"\r\n              borderRadius=\"md\"\r\n            />\r\n            <Text\r\n              className=\"action__description\"\r\n              color={isCompletedToday ? \"gray.400\" : \"gray.800\"}\r\n              fontWeight=\"bold\"\r\n              fontSize=\"lg\"\r\n              lineHeight=\"base\"\r\n              letterSpacing=\"wide\"\r\n            >\r\n              {description}\r\n            </Text>\r\n          </HStack>\r\n\r\n          {/* Quick Control Buttons Panel */}\r\n          <HStack spacing={1} shrink={0} bg=\"gray.50\" borderRadius=\"xl\" p={1}>\r\n            <IconButton\r\n              icon={<EditIcon />}\r\n              size=\"sm\"\r\n              variant=\"ghost\"\r\n              colorScheme=\"blue\"\r\n              onClick={handleModalEdit}\r\n              aria-label=\"Edit action\"\r\n              borderRadius=\"lg\"\r\n            />\r\n            <ModalEditAction\r\n              openModalEdit={openModalEdit}\r\n              handleModalEdit={handleModalEdit}\r\n              data={action}\r\n            />\r\n\r\n            <IconButton\r\n              icon={<DeleteIcon />}\r\n              size=\"sm\"\r\n              variant=\"ghost\"\r\n              colorScheme=\"red\"\r\n              onClick={handleModalDelete}\r\n              aria-label=\"Delete action\"\r\n              borderRadius=\"lg\"\r\n            />\r\n            <ModalDeleteAction\r\n              openModalDelete={openModalDelete}\r\n              handleModalDelete={handleModalDelete}\r\n              data={action}\r\n            />\r\n          </HStack>\r\n        </Flex>\r\n\r\n        {/* Footer Row: Categories and timestamps */}\r\n        <Flex\r\n          justify=\"space-between\"\r\n          alignItems=\"center\"\r\n          borderTop=\"1px dashed\"\r\n          borderColor=\"gray.100\"\r\n          pt={3}\r\n        >\r\n          <HStack spacing={3}>\r\n            <Badge\r\n              variant=\"solid\"\r\n              bg={\r\n                isCompletedToday\r\n                  ? \"green.500\"\r\n                  : `${colors.border.split(\".\")[0]}.500`\r\n              }\r\n              color=\"white\"\r\n              px={3}\r\n              py={1}\r\n              borderRadius=\"full\"\r\n              fontSize=\"xs\"\r\n              fontWeight=\"extrabold\"\r\n              letterSpacing=\"wider\"\r\n            >\r\n              {priority}\r\n            </Badge>\r\n\r\n            <Badge\r\n              variant=\"subtle\"\r\n              colorScheme=\"purple\"\r\n              px={3}\r\n              py={1}\r\n              borderRadius=\"full\"\r\n              fontSize=\"xs\"\r\n              fontWeight=\"bold\"\r\n            >\r\n              {type}\r\n            </Badge>\r\n          </HStack>\r\n\r\n          {/* Clock Display Format with Native Time Icon */}\r\n          <HStack spacing={1.5} color=\"gray.400\">\r\n            <TimeIcon boxSize=\"3.5px\" />\r\n            <Text fontSize=\"xs\" fontWeight=\"bold\" letterSpacing=\"wide\">\r\n              {format(new Date(startDate), \"HH:mm\")} &bull;{\" \"}\r\n              {format(new Date(startDate), \"dd MMM\")}\r\n            </Text>\r\n          </HStack>\r\n        </Flex>\r\n      </Flex>\r\n    </Box>\r\n  );\r\n}\r\n","D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\nav\\auth\\ModalLogin.jsx",["280","281","282"],"import React, { useEffect, useState } from \"react\";\r\nimport {\r\n  Button,\r\n  Input,\r\n  FormControl,\r\n  FormLabel,\r\n  Modal,\r\n  ModalOverlay,\r\n  ModalContent,\r\n  ModalHeader,\r\n  ModalBody,\r\n  ModalFooter,\r\n  ModalCloseButton,\r\n  VStack,\r\n  useDisclosure,\r\n} from \"@chakra-ui/react\";\r\nimport \"./ModalLogin.css\";\r\nimport { useDispatch, useSelector } from \"react-redux\";\r\nimport { useHistory } from \"react-router\";\r\nimport {\r\n  facebook_login,\r\n  google_login,\r\n  login_action,\r\n} from \"../../../actions/auth_actions\";\r\nimport isEmail from \"validator/lib/isEmail\";\r\nimport { toastr } from \"react-redux-toastr\";\r\n\r\nexport default function ModalLogin() {\r\n  const { isOpen, onOpen, onClose } = useDisclosure();\r\n  const [inputs, setInputs] = useState({ email: \"\", password: \"\" });\r\n\r\n  const { authenticated } = useSelector((state) => state.auth);\r\n  const { loading } = useSelector((state) => state.async);\r\n  const history = useHistory();\r\n  const dispatch = useDispatch();\r\n\r\n  const init = () => {\r\n    setInputs({ email: \"\", password: \"\" });\r\n    onClose();\r\n    history.push(history.location.pathname);\r\n  };\r\n\r\n  async function submitForm(e) {\r\n    e.preventDefault();\r\n    if (isEmail(inputs.email)) {\r\n      await dispatch(login_action(inputs));\r\n    } else {\r\n      toastr.error(\"error\", \"your email is not valid\");\r\n    }\r\n  }\r\n\r\n  useEffect(() => {\r\n    if (authenticated && !loading) {\r\n      init();\r\n    }\r\n  }, [authenticated, loading]);\r\n\r\n  const responseSuccesGoogle = (response) => {\r\n    dispatch(google_login({ tokenId: response.tokenId }));\r\n  };\r\n\r\n  const responseFacebook = (response) => {\r\n    dispatch(\r\n      facebook_login({\r\n        accessToken: response.accessToken,\r\n        userID: response.userID,\r\n      }),\r\n    );\r\n  };\r\n\r\n  const handleInputChange = (e) => {\r\n    setInputs({ ...inputs, [e.target.name]: e.target.value });\r\n  };\r\n\r\n  return (\r\n    <>\r\n      <Button colorScheme=\"blue\" onClick={onOpen}>\r\n        Login\r\n      </Button>\r\n\r\n      <Modal isOpen={isOpen} onClose={init} isCentered size=\"md\">\r\n        <ModalOverlay backdropFilter=\"blur(4px)\" />\r\n        <ModalContent mx={4} borderRadius=\"xl\" boxShadow=\"2xl\" p={2}>\r\n          <ModalHeader fontSize=\"2xl\" fontWeight=\"bold\" color=\"gray.800\" pb={1}>\r\n            Welcome Back\r\n          </ModalHeader>\r\n          <ModalCloseButton top=\"20px\" right=\"20px\" />\r\n\r\n          <form onSubmit={submitForm}>\r\n            <ModalBody pt={4}>\r\n              <VStack spacing={5}>\r\n                {/* Email Field Wrapper */}\r\n                <FormControl isRequired>\r\n                  <FormLabel\r\n                    fontSize=\"sm\"\r\n                    fontWeight=\"semibold\"\r\n                    color=\"gray.600\"\r\n                    mb={2}\r\n                  >\r\n                    Email Address\r\n                  </FormLabel>\r\n                  <Input\r\n                    placeholder=\"name@example.com\"\r\n                    type=\"email\"\r\n                    name=\"email\"\r\n                    onChange={handleInputChange}\r\n                    value={inputs.email}\r\n                    size=\"lg\"\r\n                    bg=\"gray.50\"\r\n                    borderWidth=\"1px\"\r\n                    borderColor=\"gray.200\"\r\n                    borderRadius=\"md\"\r\n                    _focus={{\r\n                      bg: \"white\",\r\n                      borderColor: \"blue.500\",\r\n                      boxShadow: \"0 0 0 1px #3182ce\",\r\n                    }}\r\n                  />\r\n                </FormControl>\r\n\r\n                {/* Password Field Wrapper */}\r\n                <FormControl isRequired>\r\n                  <FormLabel\r\n                    fontSize=\"sm\"\r\n                    fontWeight=\"semibold\"\r\n                    color=\"gray.600\"\r\n                    mb={2}\r\n                  >\r\n                    Password\r\n                  </FormLabel>\r\n                  <Input\r\n                    placeholder=\"Enter your password\"\r\n                    type=\"password\"\r\n                    name=\"password\"\r\n                    onChange={handleInputChange}\r\n                    value={inputs.password}\r\n                    size=\"lg\"\r\n                    bg=\"gray.50\"\r\n                    borderWidth=\"1px\"\r\n                    borderColor=\"gray.200\"\r\n                    borderRadius=\"md\"\r\n                    _focus={{\r\n                      bg: \"white\",\r\n                      borderColor: \"blue.500\",\r\n                      boxShadow: \"0 0 0 1px #3182ce\",\r\n                    }}\r\n                  />\r\n                </FormControl>\r\n              </VStack>\r\n            </ModalBody>\r\n\r\n            <ModalFooter\r\n              flexDirection=\"column\"\r\n              alignItems=\"stretch\"\r\n              gap={4}\r\n              pt={6}\r\n            >\r\n              <VStack spacing={2} width=\"100%\">\r\n                <Button\r\n                  colorScheme=\"blue\"\r\n                  type=\"submit\"\r\n                  isLoading={loading}\r\n                  width=\"100%\"\r\n                  size=\"lg\"\r\n                  fontSize=\"md\"\r\n                  fontWeight=\"bold\"\r\n                  borderRadius=\"md\"\r\n                >\r\n                  Sign In\r\n                </Button>\r\n                <Button\r\n                  variant=\"ghost\"\r\n                  onClick={init}\r\n                  width=\"100%\"\r\n                  size=\"sm\"\r\n                  color=\"gray.500\"\r\n                >\r\n                  Cancel\r\n                </Button>\r\n              </VStack>\r\n            </ModalFooter>\r\n          </form>\r\n        </ModalContent>\r\n      </Modal>\r\n    </>\r\n  );\r\n}\r\n","D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\nav\\auth\\ModalRegister.jsx",["283"],"import React, { useEffect, useState } from \"react\";\r\nimport {\r\n  Button,\r\n  Input,\r\n  FormControl,\r\n  FormLabel,\r\n  Modal,\r\n  ModalOverlay,\r\n  ModalContent,\r\n  ModalHeader,\r\n  ModalBody,\r\n  ModalFooter,\r\n  ModalCloseButton,\r\n  VStack,\r\n  useDisclosure,\r\n} from \"@chakra-ui/react\";\r\nimport \"./ModalRegister.css\";\r\nimport { register_action } from \"../../../actions/auth_actions\";\r\nimport { useDispatch, useSelector } from \"react-redux\";\r\nimport ImageUpload from \"./ImageUpload\";\r\nimport isEmail from \"validator/lib/isEmail\";\r\nimport { toastr } from \"react-redux-toastr\";\r\n\r\nexport default function ModalRegister() {\r\n  const { isOpen, onOpen, onClose } = useDisclosure();\r\n  const [inputs, setInputs] = useState({\r\n    firstName: \"\",\r\n    lastName: \"\",\r\n    email: \"\",\r\n    password: \"\",\r\n    image: null,\r\n  });\r\n\r\n  const { loading } = useSelector((state) => state.async);\r\n  const { authenticated } = useSelector((state) => state.auth);\r\n  const dispatch = useDispatch();\r\n\r\n  function getFile(file) {\r\n    setInputs({ ...inputs, image: file });\r\n  }\r\n\r\n  useEffect(() => {\r\n    if (authenticated) onClose();\r\n  }, [authenticated]);\r\n\r\n  const handleInputChange = (e) => {\r\n    setInputs({ ...inputs, [e.target.name]: e.target.value });\r\n  };\r\n\r\n  function submitForm(e) {\r\n    e.preventDefault();\r\n    const formData = new FormData();\r\n\r\n    formData.append(\"firstName\", inputs.firstName);\r\n    formData.append(\"lastName\", inputs.lastName);\r\n\r\n    if (isEmail(inputs.email)) {\r\n      formData.append(\"email\", inputs.email);\r\n    } else {\r\n      toastr.error(\"error\", \"your email is not valid\");\r\n      return;\r\n    }\r\n\r\n    if (inputs.password.length > 4) {\r\n      formData.append(\"password\", inputs.password);\r\n    } else {\r\n      toastr.error(\"error\", \"your password should be more than 4 characters\");\r\n      return;\r\n    }\r\n\r\n    formData.append(\"image\", inputs.image);\r\n    dispatch(register_action(formData));\r\n  }\r\n\r\n  return (\r\n    <>\r\n      <Button colorScheme=\"green\" onClick={onOpen}>\r\n        Register\r\n      </Button>\r\n\r\n      <Modal isOpen={isOpen} onClose={onClose} isCentered>\r\n        <ModalOverlay />\r\n        <ModalContent mx={4}>\r\n          <ModalHeader>Create your account</ModalHeader>\r\n          <ModalCloseButton />\r\n\r\n          <form onSubmit={submitForm}>\r\n            <ModalBody>\r\n              <VStack spacing={4}>\r\n                <FormControl isRequired>\r\n                  <FormLabel>First Name</FormLabel>\r\n                  <Input\r\n                    placeholder=\"First Name\"\r\n                    name=\"firstName\"\r\n                    onChange={handleInputChange}\r\n                    value={inputs.firstName}\r\n                  />\r\n                </FormControl>\r\n\r\n                <FormControl isRequired>\r\n                  <FormLabel>Last Name</FormLabel>\r\n                  <Input\r\n                    placeholder=\"Last Name\"\r\n                    name=\"lastName\"\r\n                    onChange={handleInputChange}\r\n                    value={inputs.lastName}\r\n                  />\r\n                </FormControl>\r\n\r\n                <FormControl>\r\n                  <FormLabel>Profile Picture</FormLabel>\r\n                  <ImageUpload\r\n                    id=\"image\"\r\n                    className=\"productForm_picBtn\"\r\n                    getFile={getFile}\r\n                  />\r\n                </FormControl>\r\n\r\n                <FormControl isRequired>\r\n                  <FormLabel>Email</FormLabel>\r\n                  <Input\r\n                    placeholder=\"Email\"\r\n                    type=\"email\"\r\n                    name=\"email\"\r\n                    onChange={handleInputChange}\r\n                    value={inputs.email}\r\n                  />\r\n                </FormControl>\r\n\r\n                <FormControl isRequired>\r\n                  <FormLabel>Password</FormLabel>\r\n                  <Input\r\n                    placeholder=\"Password\"\r\n                    type=\"password\"\r\n                    name=\"password\"\r\n                    onChange={handleInputChange}\r\n                    value={inputs.password}\r\n                  />\r\n                </FormControl>\r\n              </VStack>\r\n            </ModalBody>\r\n\r\n            <ModalFooter gap={3}>\r\n              <Button variant=\"ghost\" onClick={onClose} width=\"50%\">\r\n                Cancel\r\n              </Button>\r\n              <Button\r\n                colorScheme=\"green\"\r\n                type=\"submit\"\r\n                isLoading={loading}\r\n                width=\"50%\"\r\n              >\r\n                Submit\r\n              </Button>\r\n            </ModalFooter>\r\n          </form>\r\n        </ModalContent>\r\n      </Modal>\r\n    </>\r\n  );\r\n}\r\n","D:\\My projects\\Make-it-happen\\development\\client\\src\\actions\\config.js",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\actions\\async_actions.js",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\nav\\auth\\ImageUpload.js",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\actions\\promodoro_actions.js",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\action\\ModalEditAction.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\action\\ModalDeleteAction.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\field\\ModalEditField.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\field\\ModalDeleteField.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\goal\\GoalMT.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\icons\\PeersIcon.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\goal\\ModalEditGoal.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\goal\\ModalDeleteGoal.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\goal\\GoalST.jsx",[],"D:\\My projects\\Make-it-happen\\development\\client\\src\\components\\action\\ModalAddAction.jsx",[],{"ruleId":"284","replacedBy":"285"},{"ruleId":"286","replacedBy":"287"},{"ruleId":"284","replacedBy":"288"},{"ruleId":"286","replacedBy":"289"},{"ruleId":"290","severity":1,"message":"291","line":20,"column":67,"nodeType":"292","messageId":"293","endLine":20,"endColumn":74},{"ruleId":"294","severity":1,"message":"295","line":56,"column":6,"nodeType":"296","endLine":56,"endColumn":30,"suggestions":"297"},{"ruleId":"290","severity":1,"message":"298","line":58,"column":9,"nodeType":"292","messageId":"293","endLine":58,"endColumn":29},{"ruleId":"290","severity":1,"message":"299","line":62,"column":9,"nodeType":"292","messageId":"293","endLine":62,"endColumn":25},{"ruleId":"294","severity":1,"message":"300","line":44,"column":6,"nodeType":"296","endLine":44,"endColumn":21,"suggestions":"301"},"no-native-reassign",["302"],"no-negated-in-lhs",["303"],["302"],["303"],"no-unused-vars","'fieldId' is assigned a value but never used.","Identifier","unusedVar","react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'init'. Either include it or remove the dependency array.","ArrayExpression",["304"],"'responseSuccesGoogle' is assigned a value but never used.","'responseFacebook' is assigned a value but never used.","React Hook useEffect has a missing dependency: 'onClose'. Either include it or remove the dependency array.",["305"],"no-global-assign","no-unsafe-negation",{"desc":"306","fix":"307"},{"desc":"308","fix":"309"},"Update the dependencies array to be: [authenticated, init, loading]",{"range":"310","text":"311"},"Update the dependencies array to be: [authenticated, onClose]",{"range":"312","text":"313"},[1420,1444],"[authenticated, init, loading]",[1116,1131],"[authenticated, onClose]"]