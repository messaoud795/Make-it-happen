patch, useSelector } from \"react-redux\";\r\nimport { Button, Dropdown, Icon, Menu } from \"semantic-ui-react\";\r\nimport \"./Header.css\";\r\nimport ModalLogin from \"../auth/ModalLogin\";\r\nimport ModalRegister from \"../auth/ModalRegister\";\r\nimport { Link } from \"react-router-dom\";\r\nimport { logout_action } from \"../../../actions/auth_actions\";\r\n\r\nexport default function Header() {\r\n  const { authenticated, profile } = useSelector((state) => state.auth);\r\n  const [openRegister, setOpenRegister] = useState(false);\r\n  const [openLogin, setOpenLogin] = useState(false);\r\n  const dispatch = useDispatch();\r\n  console.log(profile?.image);\r\n  const handleLogout = () => {\r\n    dispatch(logout_action());\r\n  };\r\n  const handleModalLogin = () => {\r\n    setOpenLogin(!openLogin);\r\n  };\r\n\r\n  return (\r\n    <div className=\"Header\">\r\n      <Link to=\"/\" className=\"Header__logo\">\r\n        <img src={logo} alt=\"logo\" className=\"Header__img\" />\r\n        <span className=\"Header__span\">Make it happen</span>\r\n      </Link>\r\n\r\n      <div className=\"Header__auth\">\r\n        {!authenticated && (\r\n          <Button content=\"Login\" primary onClick={() => setOpenLogin(true)} />\r\n        )}\r\n        <ModalLogin open={openLogin} setOpen={handleModalLogin} />\r\n        {!authenticated && (\r\n          <Button\r\n            content=\"Register\"\r\n            positive\r\n            onClick={() => setOpenRegister(true)}\r\n          />\r\n        )}\r\n\r\n        <ModalRegister open={openRegister} setOpen={setOpenRegister} />\r\n      </div>\r\n\r\n      {authenticated && (\r\n        <Menu.Item position=\"right\" className=\"Header__menu\">\r\n          <img\r\n            src={`http://localhost:5000/${profile?.image}`}\r\n            alt=\"\"\r\n            className=\"Header__img\"\r\n          />\r\n          <Dropdown pointing=\"top right\" className=\"header__dropdown\">\r\n            <Dropdown.Menu>\r\n              <Dropdown.Item text=\"My Profile\" icon=\"user\" />\r\n              <Dropdown.Item to=\"/settings\" text=\"Settings\" icon=\"settings\" />\r\n              <Dropdown.Item\r\n                text=\"Sign Out\"\r\n                icon=\"power\"\r\n                onClick={handleLogout}\r\n              />\r\n            </Dropdown.Menu>\r\n          </Dropdown>\r\n        </Menu.Item>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n","D:\\Make-it-happen\\development\\client\\src\\components\\nav\\auth\\ModalRegister.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\components\\nav\\auth\\ModalLogin.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\pages\\GoalsPage.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\components\\field\\Field.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\components\\field\\ModalEditField.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\components\\field\\ModalDeleteField.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\components\\field\\ModalAddField.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\components\\goal\\ModalAddGoal.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\reducers\\goalReducer.js",[],"D:\\Make-it-happen\\development\\client\\src\\actions\\goal_actions.js",[],"D:\\Make-it-happen\\development\\client\\src\\components\\goal\\ModalDeleteGoal.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\components\\goal\\ModalEditGoal.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\actions\\auth_actions.js",[],"D:\\Make-it-happen\\development\\client\\src\\components\\goal\\GoalLT.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\components\\goal\\GoalMT.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\components\\goal\\GoalST.jsx",[],"D:\\Make-it-happen\\development\\client\\src\\reducers\\actionReducer.js",[],"D:\\Make-it-happen\\development\\client\\src\\components\\action\\ModalAddAction.jsx",[],["180","181"],"D:\\Make-it-happen\\development\\client\\src\\ac